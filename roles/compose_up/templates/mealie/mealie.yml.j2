include:
  - ts-service.yml

services:
  mealie:
    container_name: mealie
    image: ghcr.io/mealie-recipes/mealie:latest
    pull_policy: always
    volumes:
      - /home/ansible/{{ item.file }}/config:/app/data/
    environment:
      # Set Backend ENV Variables Here
      ALLOW_SIGNUP: "false"
      PUID: 1000
      PGID: 1000
      TZ: Europe/Paris
      BASE_URL: https://mealie.taild069bb.ts.net
    deploy:
      resources:
        limits:
          memory: 1000M
    privileged: true
    restart: unless-stopped
    network_mode: service:ts-sidecar
    depends_on:
      - ts-sidecar
  
